# ─── DATABASE ────────────────────────────────────────────────────────────────
# MongoDB Atlas M0 Cluster connection string
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/botanico

# ─── AUTHENTICATION ──────────────────────────────────────────────────────────
# Secret for signing JWTs (Run `openssl rand -base64 32` to generate)
JWT_SECRET=your_jwt_secret_here

# Initial admin password for seeding (Optional but recommended)
ADMIN_PASSWORD=secure_admin_password_here

# ─── GOOGLE DRIVE STORAGE ───────────────────────────────────────────────────
# The JSON key of your Google Service Account (flattened into a single line)
GOOGLE_SERVICE_ACCOUNT_KEY_JSON={"type": "service_account", ...}

# The ID of the root folder in Google Drive where images will be stored
DRIVE_ROOT_FOLDER_ID=1LgRUzmh30Un1sPnyGcdnFXXhSTgRGw07

# ─── OAUTH PROVIDERS ────────────────────────────────────────────────────────
# Google Cloud Console credentials
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Microsoft Azure Portal credentials
MICROSOFT_CLIENT_ID=your_microsoft_client_id
MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret

# ─── NETWORKING ──────────────────────────────────────────────────────────────
# The production URL of your backend (for CORS and OAuth callbacks)
BACKEND_URL=https://your-botanico-api.vercel.app
FRONTEND_URL=https://your-botanico-app.vercel.app
PORT=5000
NODE_ENV=production
