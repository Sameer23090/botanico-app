# ═════════════════════════════════════════════════════════════════════
# BOTANICO — INFRASTRUCTURE CONFIGURATION (EXAMPLE)
# ═════════════════════════════════════════════════════════════════════

# ─── BACKEND CONFIGURATION ──────────────────────────────────────────

# Core API Settings
PORT=5000
NODE_ENV=development
JWT_SECRET=your_ultra_secure_jwt_secret_here

# Database (MongoDB Atlas SRV)
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/botanico

# AI Intelligence (Groq Cloud)
# Get your key at: https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key

# Google Drive Storage
# JSON content from Service Account Key file
GOOGLE_SERVICE_ACCOUNT_KEY_JSON={"type":"service_account",...}
DRIVE_ROOT_FOLDER_ID=your_google_drive_folder_id

# Admin Controls
ADMIN_PASSWORD=BotanicoMaster!2024

# ─── FRONTEND CONFIGURATION ─────────────────────────────────────────

# API Base URL (Relative path for Vercel, or absolute for local dev)
# Development: http://localhost:5000/api
# Production: https://your-app.vercel.app/api
VITE_API_BASE_URL=http://localhost:5000/api

# ─── OAUTH CONFIGURATION (OPTIONAL) ─────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
MS_CLIENT_ID=your_microsoft_client_id
MS_CLIENT_SECRET=your_microsoft_client_secret

# ═════════════════════════════════════════════════════════════════════
# NOTE: Never commit actual .env files to version control.
# Copy this to .env (backend) and .env.local (frontend).
# ═════════════════════════════════════════════════════════════════════
