# ─── Server Config ─────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB Connection ─────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/botanico?retryWrites=true&w=majority

# ─── JWT Secret ─────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-this-to-something-random

# ─── Frontend URL (CORS) ─────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─── Google & Microsoft OAuth ──────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_CALLBACK_URL=http://localhost:5000/api/auth/microsoft/callback

# ─── Google Drive Storage (Service Account) ─────────────────────────────
# Set the full JSON key as a string
GOOGLE_SERVICE_ACCOUNT_KEY_JSON='{"type": "service_account", ...}'
DRIVE_ROOT_FOLDER_ID=

# ─── Google Translate API ───────────────────────────────────────────────
GOOGLE_TRANSLATE_API_KEY=
