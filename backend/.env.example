# ─── DATABASE ────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/botanico

# ─── AUTHENTICATION ──────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_here
ADMIN_PASSWORD=secure_admin_password_here

# ─── NETWORKING ──────────────────────────────────────────────────────────────
PORT=5000
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:5000
NODE_ENV=development

# ─── OAUTH PROVIDERS ────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

MICROSOFT_CLIENT_ID=your_microsoft_client_id
MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret
MICROSOFT_CALLBACK_URL=http://localhost:5000/api/auth/microsoft/callback

# ─── GOOGLE DRIVE STORAGE ───────────────────────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_KEY_JSON={"type": "service_account", ...}
DRIVE_ROOT_FOLDER_ID=1LgRUzmh30Un1sPnyGcdnFXXhSTgRGw07

# ─── EMAIL CONFIGURATION (Nodemailer) ──────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM="Botanico Support" <your-email@gmail.com>

# ─── AI ASSISTANT (Groq Llama 3) ──────────────────────────────────────
# Get free key from: https://console.groq.com/
GROQ_API_KEY=your-groq-api-key
